<Window x:Class="deduplicator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:local="clr-namespace:deduplicator" 
        xmlns:viewmodels="clr-namespace:deduplicator.ViewModels" 
        d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
        mc:Ignorable="d"
        prism:ViewModelLocator.AutoWireViewModel="True" 
        Title="Deduplicator" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <TextBox Grid.Column="0" AcceptsReturn="True" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBox Grid.Column="1" Text="{Binding ResultText}" IsReadOnly="True" />
    </Grid>
</Window>
